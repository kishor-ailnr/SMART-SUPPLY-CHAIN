# Server
PORT=3001
NODE_ENV=development

# AI / LLM (use Anthropic Claude — free tier available)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Gemini (free tier — Google AI Studio)
# Get key at: https://aistudio.google.com/app/apikey
GOOGLE_GENAI_API_KEY=your_google_gemini_key_here

# Weather (Open-Meteo — completely FREE, no key needed)
# Docs: https://open-meteo.com/en/docs
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1/forecast
AVIATION_WEATHER_BASE_URL=https://aviationweather.gov/api/data

# Routing (OpenRouteService — free tier, 2000 req/day)
# Get key at: https://openrouteservice.org/dev/#/signup
OPENROUTESERVICE_API_KEY=your_ors_key_here
OPENROUTESERVICE_BASE_URL=https://api.openrouteservice.org/v2

# Geospatial (Overpass API — completely FREE, no key needed)
# Endpoint: https://overpass-api.de/api/interpreter
OVERPASS_API_URL=https://overpass-api.de/api/interpreter
OVERPASS_CACHE_TTL_HOURS=6

# Blockchain (use Ethereum Sepolia testnet — completely FREE)
# Infura free tier: https://app.infura.io/register
INFURA_PROJECT_ID=your_infura_project_id
BLOCKCHAIN_NETWORK=sepolia

# MQTT (use free public broker for demo)
MQTT_BROKER_URL=mqtt://broker.hivemq.com
MQTT_PORT=1883

# Frontend
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001
